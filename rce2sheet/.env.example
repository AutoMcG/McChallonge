# This package uses environment variables from the root .env.example
# 
# Copy the root .env.example to .env at the repo root:
#   cp .env.example .env
#
# Then fill in the variables under the "RCE2SHEET" section.
#
# For details, see ../.env.example and the README.md

# ── Google Sheets OAuth (User Login) ──────────────────────────────────────────
# Path to OAuth client secrets JSON (Desktop app). Required for first-time authorization.
# After authorization, the token is stored in your OS keyring (Windows Credential Manager).
# On subsequent runs, you don't need to provide this if the token is already stored.
GOOGLE_OAUTH_CLIENT_SECRETS=

# Advanced: Force token storage backend. Options: "auto" (default, uses keyring),
# "keyring" (Windows Credential Manager), "file" (plaintext JSON).
# Only needed if you want to override the default keyring behavior.
RCE2SHEET_TOKEN_BACKEND=auto

# ── Google Sheets Service Account (Alternative) ────────────────────────────────
# Path to a service account credentials JSON file. Use this instead of GOOGLE_OAUTH_CLIENT_SECRETS
# if you prefer service account authentication (e.g., for CI/CD). If both are set,
# GOOGLE_OAUTH_CLIENT_SECRETS takes precedence.
GOOGLE_APPLICATION_CREDENTIALS=
