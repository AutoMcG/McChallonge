# ── Challonge API credentials ─────────────────────────────────────────────────
challonge_user=
challonge_key=

# ── Tournament IDs ─────────────────────────────────────────────────────────────
# Preferred: comma-separated list of tournament IDs or slugs
challonge_tournament_ids=

# Legacy: single tournament ID (used if challonge_tournament_ids is not set)
challonge_tt_id=

# Legacy: single tournament URL slug (kept for backwards compatibility)
challonge_tt_url=

# ── OAuth (optional, alternative to API key auth) ─────────────────────────────
CHALLONGE_CLIENT_ID=
CHALLONGE_CLIENT_SECRET=
CHALLONGE_REDIRECT_URI=

# ── Output / build ─────────────────────────────────────────────────────────────
# Directory for generated static files (default: build)
BUILD_DIR=

# Path to the local JSON cache file (default: build/tournament_cache.json)
MCCHALLONGE_CACHE_FILE=

# ── Dashboard appearance ───────────────────────────────────────────────────────
# Logo shown in the dashboard header.
# Accepts an absolute URL or a path relative to the app's static folder.
# Examples:
#   MCCHALLONGE_LOGO_URL=https://example.com/logo.png
#   MCCHALLONGE_LOGO_URL=img/logo.png
MCCHALLONGE_LOGO_URL=

# ── Client data mode for rendered pages ───────────────────────────────────────
# api   = use Flask /api/cache endpoints (local/dev)
# fixed = use fixed static files under MCCHALLONGE_CLIENT_DATA_ROOT (S3/CloudFront)
MCCHALLONGE_CLIENT_DATA_MODE=api
MCCHALLONGE_CLIENT_DATA_ROOT=/data

# ── Lambda/S3 fixed JSON publishing ───────────────────────────────────────────
# Used by mcchallonge.lambda_handlers.update_data
MCCHALLONGE_DATA_BUCKET=
MCCHALLONGE_DATA_PREFIX=data