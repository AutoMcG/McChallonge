# ═══════════════════════════════════════════════════════════════════════════════
# McChallonge Monorepo Configuration
#
# Copy this file to .env at the repo root and fill in your credentials.
# This file is automatically loaded by all packages (mcchallonge, rce2sheet, etc).
# Never commit .env to version control — it is already in .gitignore.
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# MCCHALLONGE — Challonge API integration & bracket management
# ─────────────────────────────────────────────────────────────────────────────────

# Challonge account credentials (required for basic auth API access)
# Get from: https://challonge.com/settings/developer
challonge_user=
challonge_key=

# Tournament ID(s) for the mcchallonge dashboard (optional)
# Preferred: comma-separated list of tournament IDs or slugs
challonge_tournament_ids=

# Legacy support: single tournament ID (used if challonge_tournament_ids not set)
challonge_tt_id=

# Legacy support: single tournament URL slug (kept for backwards compatibility)
challonge_tt_url=

# Dashboard logo URL (optional)
# Accepts absolute URL or path relative to app's static folder
# Examples:
#   MCCHALLONGE_LOGO_URL=https://example.com/logo.png
#   MCCHALLONGE_LOGO_URL=img/logo.png
MCCHALLONGE_LOGO_URL=

# ─────────────────────────────────────────────────────────────────────────────────
# RCE2SHEET — Google Sheets integration for check-in tracking
# ─────────────────────────────────────────────────────────────────────────────────

# Google OAuth client secrets for user login flow (optional)
# Get from: Google Cloud Console > Create OAuth 2.0 credentials (Desktop app)
# If set, rce2sheet will use this instead of requiring --oauth-client-secrets on CLI.
# After first authorization, the token is stored in OS keyring automatically.
# On subsequent runs, you don't need this if the token is already stored.
GOOGLE_OAUTH_CLIENT_SECRETS=

# Google Sheets API authentication via service account (optional, alternative to OAuth)
# Get from: Google Cloud Console > Service Account > Create service account key
# Use this if you prefer service account auth (e.g., for CI/CD).
# If both GOOGLE_OAUTH_CLIENT_SECRETS and GOOGLE_APPLICATION_CREDENTIALS are set,
# GOOGLE_OAUTH_CLIENT_SECRETS takes precedence.
GOOGLE_APPLICATION_CREDENTIALS=

# Advanced: Force rce2sheet token storage backend (optional)
# Options: "auto" (default, prefers keyring), "keyring", "file"
# Only change this if you want to override the default keyring behavior.
RCE2SHEET_TOKEN_BACKEND=auto

# ─────────────────────────────────────────────────────────────────────────────────
# SHARED — Used by multiple packages
# ─────────────────────────────────────────────────────────────────────────────────

# Build output directory (default: build)
# Used by: mcchallonge, mcrobotcombatevents
BUILD_DIR=

# Local tournament cache file path (default: build/tournament_cache.json)
# Used by: mcchallonge dashboard to store tournament state
MCCHALLONGE_CACHE_FILE=
